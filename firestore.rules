rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'aelbshlawy13@gmail.com' && request.auth.token.email_verified == true;
    }

    function isValidStatus(data) {
      return data.keys().hasAll(['toggled']) && data.toggled is bool;
    }

    match /system/status {
      allow get, list: if true;
      allow create: if isAdmin() && isValidStatus(incoming());
      allow update: if (
        isAdmin() && 
        isValidStatus(incoming()) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['toggled'])
      );
      allow delete: if false;
    }
  }
}
